TG_API_ID=replace-me
TG_API_HASH=replace-me

# Path prefix for the Telethon session file.
# Example:
# TG_SESSION_NAME=/Users/yourname/telegram_user
TG_SESSION_NAME=telegram_user

# Source chat: where the script reads messages from.
# Can be a public username, numeric chat id, or a title resolvable by Telethon.
TG_SUMMARY_CHAT=vibecod3rs
TG_SUMMARY_CHAT_LABEL=vibecod3rs

# Time window and output settings.
TG_SUMMARY_WINDOW=yesterday
TG_SUMMARY_TIMEZONE=Europe/Moscow
TG_SUMMARY_OUTPUT_DIR=output/telegram_daily_html

# Destination chat: where the summary should be posted.
# Use `me` for Saved Messages or a numeric channel/chat id.
TG_SUMMARY_DESTINATION_CHAT=me
